### Example environment variables (do NOT commit real secrets)
# Copy this file to `.env.local` and fill the values locally.

# App URL
APP_URL="https://your-app.example.com"

# Vercel OIDC token (if used) - do NOT commit a real token
# VERCEL_OIDC_TOKEN="your_vercel_oidc_token_here"

# DeepSeek / Gemini API key (server or client, depending on usage)
VITE_DEEPSEEK_API_KEY="your_deepseek_api_key_here"
DEEPSEEK_API_KEY="your_deepseek_api_key_here"

# Supabase (required)
VITE_SUPABASE_URL="https://your-supabase-instance.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key_here"

# Other optional env vars
APP_ENV=development
# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase - Banco de dados da plataforma
VITE_SUPABASE_URL="https://<seu-projeto>.supabase.co"
VITE_SUPABASE_ANON_KEY="<sua-anon-key>"
